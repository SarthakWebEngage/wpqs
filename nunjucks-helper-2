<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Nunjucks Builder – WebEngage</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/tokyo-night-dark.min.css">
<script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#0e1117;--bg2:#151b25;--bg3:#1c2333;
  --border:#2a3548;--border2:#364056;
  --text:#cdd6f4;--text2:#8892a4;--text3:#556070;
  --accent:#7aa2f7;--green:#9ece6a;--teal:#2ac3de;
  --orange:#ff9e64;--rose:#f7768e;--purple:#bb9af7;--yellow:#e0af68;
  --if-c:#7aa2f7;--for-c:#9ece6a;--set-c:#bb9af7;
  --text-c:#565f89;--rec-c:#2ac3de;--soc-c:#ff9e64;--grid-c:#f7768e;
  --r:8px;--rs:5px;
  font-family:'DM Sans',sans-serif;
}
html,body{height:100%}
body{background:var(--bg);color:var(--text);font-size:13px;overflow:hidden}
.app{display:flex;height:100vh}
/* ── left panel ── */
.lpanel{width:228px;flex-shrink:0;background:var(--bg2);border-right:1px solid var(--border);display:flex;flex-direction:column;overflow:hidden}
.lhdr{padding:15px 14px 11px;border-bottom:1px solid var(--border)}
.lhdr h1{font-size:15px;font-weight:700;letter-spacing:-.02em;color:#fff}
.lhdr p{font-size:10px;color:var(--text3);margin-top:2px;font-family:'JetBrains Mono',monospace}
.palette{flex:1;overflow-y:auto;padding:10px 8px}
.pal-sec{margin-bottom:16px}
.pal-lbl{font-size:10px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:var(--text3);padding:0 6px;margin-bottom:5px;display:block}
.pal-btn{display:flex;align-items:center;gap:9px;width:100%;padding:7px 10px;border-radius:var(--rs);border:1px solid transparent;background:transparent;color:var(--text);cursor:pointer;text-align:left;font-family:'DM Sans',sans-serif;font-size:12px;font-weight:500;transition:background .12s,border-color .12s;margin-bottom:2px}
.pal-btn:hover{background:var(--bg3);border-color:var(--border)}
.pal-icon{font-size:15px;line-height:1;width:20px;text-align:center;flex-shrink:0}
.pal-text{flex:1}.pal-name{display:block}.pal-hint{display:block;font-size:10px;color:var(--text3);font-weight:400;margin-top:1px}
.pal-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0}
[data-type=if]   .pal-dot{background:var(--if-c)}
[data-type=for]  .pal-dot{background:var(--for-c)}
[data-type=set]  .pal-dot{background:var(--set-c)}
[data-type=text] .pal-dot{background:var(--text-c)}
[data-type=rec]  .pal-dot{background:var(--rec-c)}
[data-type=social].pal-dot{background:var(--soc-c)}
[data-type=grid] .pal-dot{background:var(--grid-c)}
.pal-div{height:1px;background:var(--border);margin:4px 6px 10px}
.preset-btn{display:block;width:100%;padding:7px 10px;border-radius:var(--rs);border:1px solid var(--border);background:transparent;color:var(--text2);cursor:pointer;text-align:left;font-family:'DM Sans',sans-serif;font-size:11px;transition:all .12s;margin-bottom:4px}
.preset-btn:hover{background:var(--bg3);color:var(--text);border-color:var(--border2)}
.preset-btn span{display:block;font-size:10px;color:var(--text3);margin-top:1px}
/* ── center panel ── */
.cpanel{flex:1;display:flex;flex-direction:column;overflow:hidden;min-width:0}
.chdr{padding:9px 16px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:8px;background:var(--bg2);flex-shrink:0}
.ctitle{font-size:11px;font-weight:600;color:var(--text3);letter-spacing:.05em;text-transform:uppercase;flex:1}
.c-act-btn{padding:3px 10px;border-radius:var(--rs);border:1px solid var(--border2);background:transparent;color:var(--text2);font-family:'DM Sans',sans-serif;font-size:11px;cursor:pointer;transition:all .12s}
.c-act-btn:hover{background:var(--bg3);color:var(--text)}
.cscroll{flex:1;overflow-y:auto;padding:14px}
#root{min-height:100%}
.cempty{display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:200px;gap:10px;color:var(--text3);text-align:center;border:2px dashed var(--border);border-radius:var(--r);padding:36px}
.cempty .ce-ico{font-size:32px;opacity:.5}
.cempty p{font-size:12px;line-height:1.7}
/* ── right panel ── */
.rpanel{width:370px;flex-shrink:0;background:var(--bg2);border-left:1px solid var(--border);display:flex;flex-direction:column;overflow:hidden}
.ohdr{padding:9px 14px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:8px;flex-shrink:0}
.otitle{font-size:11px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:var(--text3);flex:1}
.o-btn{padding:4px 12px;border-radius:var(--rs);border:1px solid var(--border2);background:transparent;color:var(--text2);font-family:'DM Sans',sans-serif;font-size:11px;font-weight:500;cursor:pointer;transition:all .12s}
.o-btn:hover{background:var(--bg3);color:var(--text)}
.o-btn.primary{background:rgba(122,162,247,.14);color:var(--accent);border-color:rgba(122,162,247,.3)}
.o-btn.primary:hover{background:rgba(122,162,247,.24)}
.obody{flex:1;overflow-y:auto;padding:12px 14px}
.obody pre{margin:0}
.obody code{font-family:'JetBrains Mono',monospace!important;font-size:11px!important;line-height:1.65!important}
.hljs{background:transparent!important;padding:0!important}
/* ── block cards ── */
.bwrap{margin-bottom:8px}
.bcard{border-radius:var(--r);border:1px solid var(--border);background:var(--bg3);position:relative}
.bcard::before{content:'';position:absolute;left:0;top:0;bottom:0;width:3px;border-radius:var(--r) 0 0 var(--r)}
.block-if   .bcard::before{background:var(--if-c)}
.block-for  .bcard::before{background:var(--for-c)}
.block-set  .bcard::before{background:var(--set-c)}
.block-text .bcard::before{background:var(--text-c)}
.block-rec  .bcard::before{background:var(--rec-c)}
.block-social.bcard::before{background:var(--soc-c)}
.block-grid .bcard::before{background:var(--grid-c)}
.bhdr{display:flex;align-items:center;gap:8px;padding:8px 10px 8px 14px;border-bottom:1px solid var(--border)}
.bbadge{font-family:'JetBrains Mono',monospace;font-size:10px;font-weight:600;letter-spacing:.06em;padding:2px 7px;border-radius:3px;text-transform:uppercase;flex-shrink:0}
.badge-if    {background:rgba(122,162,247,.15);color:var(--if-c)}
.badge-for   {background:rgba(158,206,106,.15);color:var(--for-c)}
.badge-set   {background:rgba(187,154,247,.15);color:var(--set-c)}
.badge-text  {background:rgba(86,95,137,.2);color:#737aa2}
.badge-rec   {background:rgba(42,195,222,.12);color:var(--rec-c)}
.badge-social{background:rgba(255,158,100,.12);color:var(--soc-c)}
.badge-grid  {background:rgba(247,118,142,.12);color:var(--grid-c)}
.blbl{flex:1;font-size:11px;color:var(--text2);font-weight:500}
.bctrl{display:flex;gap:3px;align-items:center}
.ibtn{background:none;border:none;cursor:pointer;color:var(--text3);font-size:13px;padding:2px 5px;border-radius:3px;line-height:1;transition:color .1s,background .1s;font-family:'DM Sans',sans-serif}
.ibtn:hover{color:var(--text);background:var(--bg2)}
.ibtn.del:hover{color:var(--rose)}
.bbody{padding:10px 12px 12px 14px}
.bbody.collapsed{display:none}
/* ── form ── */
.frow{display:flex;align-items:center;gap:8px;margin-bottom:8px;flex-wrap:wrap}
.frow:last-child{margin-bottom:0}
.flbl{font-size:11px;color:var(--text3);white-space:nowrap;min-width:70px}
.ctrl{background:var(--bg2);border:1px solid var(--border);border-radius:var(--rs);color:var(--text);font-family:'JetBrains Mono',monospace;font-size:11px;padding:4px 8px;outline:none;transition:border-color .12s}
.ctrl:focus{border-color:var(--accent)}
select.ctrl{cursor:pointer}
textarea.ctrl{resize:none;overflow:hidden;min-height:52px;width:100%;line-height:1.5}
/* ── token picker ── */
.tpick{position:relative;display:inline-flex;align-items:center}
.tp-cat{background:var(--bg2);border:1px solid var(--border);border-right:none;border-radius:var(--rs) 0 0 var(--rs);color:var(--text3);font-family:'DM Sans',sans-serif;font-size:10px;padding:4px 5px;cursor:pointer;white-space:nowrap}
.tp-wrap{position:relative}
.tp-srch{background:var(--bg2);border:1px solid var(--border);border-radius:0 var(--rs) var(--rs) 0;color:var(--text);font-family:'JetBrains Mono',monospace;font-size:11px;padding:4px 8px;width:155px;outline:none;transition:border-color .12s}
.tp-srch:focus{border-color:var(--accent)}
.tp-dd{position:absolute;top:calc(100% + 3px);left:0;z-index:999;min-width:240px;max-height:220px;overflow-y:auto;background:var(--bg);border:1px solid var(--border2);border-radius:var(--rs);box-shadow:0 8px 30px rgba(0,0,0,.5);display:none}
.tp-dd.open{display:block}
.tp-grp{padding:5px 10px 2px;font-size:10px;color:var(--text3);text-transform:uppercase;letter-spacing:.06em;font-family:'DM Sans',sans-serif}
.tp-item{padding:5px 12px;font-size:11px;color:var(--text2);cursor:pointer;font-family:'JetBrains Mono',monospace;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.tp-item:hover{background:var(--bg3);color:var(--text)}
/* ── child area ── */
.child-area{margin-top:9px;border-radius:var(--rs);background:rgba(0,0,0,.2);border:1px dashed var(--border);padding:8px;min-height:40px}
.child-lbl{font-size:10px;color:var(--text3);letter-spacing:.06em;text-transform:uppercase;margin-bottom:5px;font-weight:600}
.add-row{display:flex;gap:5px;margin-top:7px;flex-wrap:wrap}
.acb{font-family:'DM Sans',sans-serif;font-size:10px;font-weight:600;padding:3px 9px;border-radius:4px;border:none;cursor:pointer;opacity:.75;transition:opacity .1s}
.acb:hover{opacity:1}
.acb-if  {background:rgba(122,162,247,.2);color:var(--if-c)}
.acb-for {background:rgba(158,206,106,.15);color:var(--for-c)}
.acb-text{background:rgba(86,95,137,.2);color:#737aa2}
.acb-set {background:rgba(187,154,247,.15);color:var(--set-c)}
/* ── elif/else ── */
.elif-blk{border-left:2px solid var(--purple);background:rgba(187,154,247,.04);border-radius:0 var(--rs) var(--rs) 0;padding:8px 10px;margin-top:6px}
.else-blk{border-left:2px solid var(--yellow);background:rgba(224,175,104,.04);border-radius:0 var(--rs) var(--rs) 0;padding:8px 10px;margin-top:6px}
.btag{font-family:'JetBrains Mono',monospace;font-size:10px;font-weight:700;letter-spacing:.08em;padding:2px 6px;border-radius:3px;text-transform:uppercase}
.btag-elif{background:rgba(187,154,247,.15);color:var(--purple)}
.btag-else{background:rgba(224,175,104,.15);color:var(--yellow)}
.elif-hdr{display:flex;align-items:center;gap:6px;margin-bottom:6px;flex-wrap:wrap}
.bab-row{display:flex;gap:6px;margin-top:9px}
.bab{font-family:'DM Sans',sans-serif;font-size:10px;font-weight:600;padding:3px 9px;border-radius:4px;border:none;cursor:pointer;opacity:.8;transition:opacity .1s}
.bab:hover{opacity:1}
.bab-elif{background:rgba(187,154,247,.2);color:var(--purple)}
.bab-else{background:rgba(224,175,104,.2);color:var(--yellow)}
/* ── condition ── */
.cond-row{display:flex;align-items:center;gap:6px;margin-bottom:4px;flex-wrap:wrap}
.cond-ao{font-family:'JetBrains Mono',monospace;font-size:10px;padding:3px 6px;background:rgba(187,154,247,.15);color:var(--purple);border:none;border-radius:4px;cursor:pointer;font-weight:600}
.cond-del{background:none;border:none;color:var(--text3);cursor:pointer;font-size:13px;padding:1px 4px;border-radius:3px;line-height:1}
.cond-del:hover{color:var(--rose)}
.add-cond{font-family:'DM Sans',sans-serif;font-size:10px;font-weight:600;padding:3px 9px;border-radius:4px;border:none;cursor:pointer;background:rgba(122,162,247,.14);color:var(--if-c);opacity:.8;transition:opacity .1s;margin-top:4px;display:inline-block}
.add-cond:hover{opacity:1}
/* ── set tabs ── */
.set-tabs{display:flex;gap:2px;margin-bottom:8px}
.stab{font-family:'DM Sans',sans-serif;font-size:10px;font-weight:600;padding:3px 10px;border-radius:4px;border:none;cursor:pointer;background:var(--bg2);color:var(--text3);transition:all .12s}
.stab.on{background:rgba(187,154,247,.2);color:var(--set-c)}
/* ── rec config ── */
.rec-cfg{background:rgba(42,195,222,.05);border:1px solid rgba(42,195,222,.15);border-radius:var(--rs);padding:10px 12px;margin-bottom:10px}
.rcfg-ttl{font-size:11px;font-weight:600;color:var(--rec-c);margin-bottom:8px}
.chk-row{display:flex;align-items:center;gap:6px;margin-bottom:5px}
.chk-row input{accent-color:var(--rec-c);cursor:pointer}
.chk-row label{font-size:11px;color:var(--text2);cursor:pointer}
.chk-hint{font-size:10px;color:var(--text3)}
/* ── grid config ── */
.grid-cfg{background:rgba(247,118,142,.05);border:1px solid rgba(247,118,142,.2);border-radius:var(--rs);padding:10px 12px;margin-bottom:10px}
.gcfg-ttl{font-size:11px;font-weight:600;color:var(--grid-c);margin-bottom:8px}
.fpill{display:inline-flex;align-items:center;gap:4px;font-family:'JetBrains Mono',monospace;font-size:10px;padding:2px 8px;border-radius:3px;background:rgba(247,118,142,.12);color:var(--grid-c);margin:2px}
.fpill .fp-del{background:none;border:none;cursor:pointer;color:rgba(247,118,142,.5);font-size:12px;line-height:1;padding:0}
.fpill .fp-del:hover{color:var(--rose)}
.fields-wrap{margin-bottom:7px;min-height:28px}
/* ── social ── */
.soc-row{border:1px solid var(--border);border-radius:var(--rs);padding:10px;margin-bottom:7px}
.soc-row:last-child{margin-bottom:0}
.soc-hdr{display:flex;align-items:center;gap:8px;margin-bottom:8px}
.cflag{font-size:17px}
.cname{font-size:12px;font-weight:600}
.cbadge{font-family:'JetBrains Mono',monospace;font-size:9px;padding:1px 5px;border-radius:3px;margin-left:auto}
.cbadge-if  {background:rgba(122,162,247,.15);color:var(--if-c)}
.cbadge-elif{background:rgba(187,154,247,.15);color:var(--purple)}
.cbadge-else{background:rgba(224,175,104,.15);color:var(--yellow)}
.soc-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:6px}
.soc-field label{display:block;font-size:9px;color:var(--text3);text-transform:uppercase;letter-spacing:.06em;margin-bottom:3px;font-weight:600}
.add-cntry{width:100%;padding:6px;border:1px dashed var(--border2);background:transparent;color:var(--text3);border-radius:var(--rs);cursor:pointer;font-family:'DM Sans',sans-serif;font-size:11px;transition:all .12s;margin-top:5px}
.add-cntry:hover{background:var(--bg3);color:var(--text2)}
.del-cntry{margin-left:auto;background:none;border:none;cursor:pointer;color:var(--text3);font-size:12px;padding:2px 5px;border-radius:3px}
.del-cntry:hover{color:var(--rose)}
/* ── info box ── */
.ibox{background:rgba(122,162,247,.07);border:1px solid rgba(122,162,247,.15);border-radius:var(--rs);padding:7px 10px;font-size:11px;color:var(--text2);margin-bottom:9px;line-height:1.6}
.ibox code,.mono{font-family:'JetBrains Mono',monospace;font-size:10px;background:rgba(122,162,247,.12);padding:1px 5px;border-radius:3px;color:var(--accent)}
.sep{height:1px;background:var(--border);margin:7px 0}
::-webkit-scrollbar{width:4px;height:4px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px}
</style>
</head>
<body>
<div class="app">

<!-- LEFT -->
<aside class="lpanel">
  <div class="lhdr">
    <h1>Nunjucks Builder</h1>
    <p>WebEngage · Personalization</p>
  </div>
  <div class="palette">
    <div class="pal-sec">
      <span class="pal-lbl">Logic Blocks</span>
      <button class="pal-btn" data-type="if"   onclick="rootAdd('if')">
        <span class="pal-icon">🔀</span><span class="pal-text"><span class="pal-name">IF / ELIF / ELSE</span><span class="pal-hint">Conditional branch</span></span><span class="pal-dot"></span>
      </button>
      <button class="pal-btn" data-type="for"  onclick="rootAdd('for')">
        <span class="pal-icon">🔁</span><span class="pal-text"><span class="pal-name">FOR Loop</span><span class="pal-hint">Iterate a catalog or array</span></span><span class="pal-dot"></span>
      </button>
      <button class="pal-btn" data-type="set"  onclick="rootAdd('set')">
        <span class="pal-icon">📌</span><span class="pal-text"><span class="pal-name">SET Variable</span><span class="pal-hint">Token, date filter, or value</span></span><span class="pal-dot"></span>
      </button>
    </div>
    <div class="pal-sec">
      <span class="pal-lbl">Smart Presets</span>
      <button class="pal-btn" data-type="rec"    onclick="rootAdd('rec')">
        <span class="pal-icon">🎯</span><span class="pal-text"><span class="pal-name">Recommendation</span><span class="pal-hint">xargs + fail-guard + loop</span></span><span class="pal-dot"></span>
      </button>
      <button class="pal-btn" data-type="grid"   onclick="rootAdd('grid')">
        <span class="pal-icon">🃏</span><span class="pal-text"><span class="pal-name">2-Col Card Grid</span><span class="pal-hint">left / right pair loop</span></span><span class="pal-dot"></span>
      </button>
      <button class="pal-btn" data-type="social" onclick="rootAdd('social')">
        <span class="pal-icon">🌐</span><span class="pal-text"><span class="pal-name">Social URLs</span><span class="pal-hint">Country-based if/elif/else</span></span><span class="pal-dot"></span>
      </button>
    </div>
    <div class="pal-sec">
      <span class="pal-lbl">Content</span>
      <button class="pal-btn" data-type="text" onclick="rootAdd('text')">
        <span class="pal-icon">✏️</span><span class="pal-text"><span class="pal-name">Text / HTML</span><span class="pal-hint">Raw content + token inserter</span></span><span class="pal-dot"></span>
      </button>
    </div>
    <div class="pal-div"></div>
    <div class="pal-sec">
      <span class="pal-lbl">Quick Start</span>
      <button class="preset-btn" onclick="loadPreset('rec_email')">🎯 Full recommendation email<span>Rec + card grid + social footer</span></button>
      <button class="preset-btn" onclick="loadPreset('greeting')">👋 Personalised greeting<span>SET first name with fallback</span></button>
      <button class="preset-btn" onclick="loadPreset('geo')">🗺️ Geo-personalised content<span>Country IF / ELIF / ELSE</span></button>
    </div>
  </div>
</aside>

<!-- CENTER -->
<main class="cpanel">
  <div class="chdr">
    <span class="ctitle">Template Canvas</span>
    <button class="c-act-btn" onclick="collapseAll()">Collapse all</button>
    <button class="c-act-btn" onclick="expandAll()">Expand all</button>
    <button class="c-act-btn" onclick="clearAll()">Clear</button>
  </div>
  <div class="cscroll">
    <div id="root">
      <div class="cempty" id="cempty">
        <div class="ce-ico">🧩</div>
        <p>Pick a block from the left panel<br>or start with a <strong>Quick Start</strong> preset.<br><br>Output compiles live →</p>
      </div>
    </div>
  </div>
</main>

<!-- RIGHT -->
<aside class="rpanel">
  <div class="ohdr">
    <span class="otitle">Generated Nunjucks</span>
    <button class="o-btn primary" id="copy-btn" onclick="copyCode()">Copy</button>
  </div>
  <div class="obody">
    <pre><code id="output" class="language-twig"></code></pre>
  </div>
</aside>
</div>

<script>
'use strict';
// ══════════════════════════════ DATA ══════════════════════════════
const TOKENS = {
  userSystem:[
    {name:'first_name',label:'First Name'},{name:'last_name',label:'Last Name'},
    {name:'birth_date',label:'Date of Birth'},{name:'phone',label:'Phone Number'},
    {name:'hashed_phone',label:'Hashed Phone'},{name:'gender',label:'Gender'},
    {name:'email',label:'Email Address'},{name:'hashed_email',label:'Hashed Email'},
    {name:'company',label:'Company'},{name:'tz_name',label:'Time Zone'},
    {name:'cuid',label:'User ID (cuid)'},
  ],
  userCustom:[
    {name:'City of Interest'},{name:'Country of Interest'},{name:'Country'},
    {name:'c_sdk_type'},{name:'postal_code'},{name:'address'},{name:'age'},{name:'Age'},
    {name:'Theme'},{name:'mobile'},{name:'Person Type'},{name:'Subscribed to email'},
    {name:'NumberOfItems'},{name:'userId'},{name:'state'},{name:'utm_source'},
    {name:'isCartItemPresent'},{name:'Twitter username'},{name:'previousPurchasedAMCPlan'},
  ],
  eventCustom:[
    {name:'Genre 1'},{name:'Genre 2'},{name:'Nationality 1'},{name:'Nationality 2'},
    {name:'Broad Type 1'},{name:'Broad Type 2'},{name:'Festive/Sport/Gaming'},
