function mkPicker(){
  const pid=npc();
  return `<div class="tpick" data-pid="${pid}">
    <select class="tp-cat" data-role="cat">${CATS.map(c=>`<option value="${c.key}">${c.label}</option>`).join('')}</select>
    <div class="tp-wrap">
      <input class="tp-srch" data-role="srch" placeholder="search attribute…" autocomplete="off">
      <div class="tp-dd" data-role="dd"></div>
    </div>
    <input type="hidden" data-role="val">
  </div>`;
}
function initPicker(p){
  if(p.dataset.init) return; p.dataset.init='1';
  const cat=p.querySelector('[data-role=cat]');
  const srch=p.querySelector('[data-role=srch]');
  const dd=p.querySelector('[data-role=dd]');
  const hid=p.querySelector('[data-role=val]');
  function toks(){return TOKENS[cat.value]||[]}
  function render(q=''){
    const fl=q?toks().filter(t=>(t.name+(t.label||'')).toLowerCase().includes(q.toLowerCase())):toks();
    const c=CATS.find(c=>c.key===cat.value);
    dd.innerHTML=`<div class="tp-grp">${c.label}</div>`+
      (fl.length?fl.map(t=>`<div class="tp-item" data-name="${t.name}">${t.label||t.name}</div>`).join(''):'<div class="tp-item" style="color:var(--text3)">No results</div>');
    dd.classList.add('open');
  }
  cat.addEventListener('change',()=>{srch.value='';hid.value='';render();compile()});
  srch.addEventListener('focus',()=>render(srch.value));
  srch.addEventListener('input',()=>{render(srch.value);compile()});
  dd.addEventListener('mousedown',e=>{
    const item=e.target.closest('.tp-item');
    if(!item||!item.dataset.name) return;
    e.preventDefault();hid.value=item.dataset.name;srch.value=item.dataset.name;
    dd.classList.remove('open');compile();
  });
  document.addEventListener('click',e=>{if(!p.contains(e.target))dd.classList.remove('open')},true);
}
function initPickers(el){el.querySelectorAll('.tpick:not([data-init])').forEach(initPicker)}

