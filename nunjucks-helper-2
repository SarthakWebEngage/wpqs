const MAKERS={if:mkIF,for:mkFOR,set:mkSET,text:mkTEXT,rec:mkREC,grid:mkGRID,social:mkSOCIAL};

function addBlock(container,type){
  const bid=nid();
  const tpl=MAKERS[type];if(!tpl)return null;
  const d=document.createElement('div');d.innerHTML=tpl(bid).trim();
  const el=d.firstElementChild;
  container.appendChild(el);
  wireBlock(el,bid,type);
  initPickers(el);
  wireInputs(el);
  syncEmpty();compile();
  return el;
}
function rootAdd(type){addBlock(root,type)}
function removeBlock(bid){document.querySelector(`[data-bid="${bid}"]`)?.remove();syncEmpty();compile()}

function wireBlock(el,bid,type){
  // child area delegation
  el.addEventListener('click',e=>{
    const b=e.target.closest('.acb');if(!b)return;e.stopPropagation();
    const slot=b.dataset.slot,t=b.dataset.add;
    const cont=b.closest(`[data-slot="${slot}"]`)?.querySelector(`[data-cont="${slot}"]`);
    if(cont)addBlock(cont,t);
  });
  // FOR toggles
  if(type==='for'){
    const cs=el.querySelector('.for-col'),cc=el.querySelector('.for-col-cust'),hint=el.querySelector('.for-hint');
    cs?.addEventListener('change',()=>{
      cc.style.display=cs.value==='__custom__'?'inline-block':'none';
      if(cs.value&&cs.value!=='__custom__'){
        const f=COLLECTIONS.find(c=>c.value===cs.value);
        if(f){hint.innerHTML=`<span style="font-size:11px;background:rgba(42,195,222,.1);color:var(--teal);padding:3px 9px;border-radius:3px;font-family:'JetBrains Mono',monospace;">ℹ️ ${f.hint} — use {{ item.field_name }}</span>`;hint.style.display='block';}
      }else hint.style.display='none';
      compile();
    });
  }
  // REC slug toggle
  if(type==='rec'){
    const rs=el.querySelector('.rec-slug'),rc=el.querySelector('.rec-slug-cust');
    rs?.addEventListener('change',()=>{rc.style.display=rs.value==='__custom__'?'inline-block':'none';compile();});
  }
  // GRID field select
  if(type==='grid'){
    const gs=el.querySelector('.gf-sel'),gc=el.querySelector('.gf-cust');
    gs?.addEventListener('change',()=>{gc.style.display=gs.value==='__custom__'?'inline-block':'none';});
  }
}

// ══════════════════════════════ UI ACTIONS ═══════════════════
function toggleC(bid){
  const body=document.querySelector(`[data-body="${bid}"]`);
  const btn=document.querySelector(`[data-bid="${bid}"] .ibtn`);
  if(!body)return;
  const c=body.classList.toggle('collapsed');
  if(btn)btn.textContent=c?'▸':'▾';
}
function collapseAll(){document.querySelectorAll('[data-body]').forEach(b=>{b.classList.add('collapsed');const btn=document.querySelector(`[data-bid="${b.dataset.body}"] .ibtn`);if(btn)btn.textContent='▸';})}
function expandAll(){document.querySelectorAll('[data-body]').forEach(b=>{b.classList.remove('collapsed');const btn=document.querySelector(`[data-bid="${b.dataset.body}"] .ibtn`);if(btn)btn.textContent='▾';})}
function clearAll(){if(!confirm('Clear canvas?'))return;root.innerHTML='';root.appendChild(cempty);syncEmpty();compile()}

function setMode(tabEl,mode){
  const body=tabEl.closest('.bbody');
  body.querySelectorAll('.stab').forEach(t=>t.classList.remove('on'));tabEl.classList.add('on');
  body.querySelectorAll('.set-panel').forEach(p=>p.style.display='none');
  body.querySelector(`[data-panel="${mode}"]`).style.display='block';
  compile();
}

function insertToken(btn){
  const row=btn.closest('.frow');
  const p=row.querySelector('.tpick');
  const cat=p?.querySelector('[data-role=cat]')?.value||'userSystem';
  const attr=p?.querySelector('[data-role=val]')?.value?.trim()||'';
  if(!attr){alert('Pick an attribute first');return}
  const token=`{{ ${buildPath(cat,attr)} }}`;
  const ta=btn.closest('.bbody').querySelector('.content-ta');
  if(!ta)return;
  const pos=ta.selectionStart||ta.value.length;
  ta.value=ta.value.slice(0,pos)+token+ta.value.slice(pos);
  ta.dispatchEvent(new Event('input'));
}

function addGridField(btn){
  const body=btn.closest('.bbody');
  const sel=body.querySelector('.gf-sel'),cust=body.querySelector('.gf-cust');
  const f=sel.value==='__custom__'?cust.value.trim():sel.value;
  if(!f)return;
  const wrap=body.querySelector('.grid-fields');
  const d=document.createElement('span');d.innerHTML=mkPill(f);
  wrap.appendChild(d.firstElementChild);compile();
}

function addElif(btn){
  const body=btn.closest('.bbody');
  const list=body.querySelector('.elif-list');
  const eid=nid();
  const d=document.createElement('div');
  d.innerHTML=`<div class="elif-blk" data-elif="${eid}">
    <div class="elif-hdr">
      <span class="btag btag-elif">ELIF</span>
      <div class="cond-rows">${mkCondRow(true)}</div>
      <button class="add-cond" onclick="addCond(this)" style="margin-left:5px;">+ AND</button>
      <button class="ibtn del" onclick="this.closest('[data-elif]').remove();compile()" style="margin-left:auto;">✕</button>
    </div>
    ${mkChild('ELIF body',`elif_${eid}`)}
  </div>`;
  const el=d.firstElementChild;
  list.appendChild(el);
  el.addEventListener('click',e=>{
    const b=e.target.closest('.acb');if(!b)return;e.stopPropagation();
    const slot=b.dataset.slot,t=b.dataset.add;
    const cont=b.closest(`[data-slot="${slot}"]`)?.querySelector(`[data-cont="${slot}"]`);
    if(cont)addBlock(cont,t);
  });
  initPickers(el);wireInputs(el);compile();
}

function addElse(btn){
  const body=btn.closest('.bbody');
  const wrap=body.querySelector('.else-wrap');
  if(wrap.style.display!=='none')return;
  const eid=nid();
  wrap.innerHTML=`<div class="else-blk">
    <div class="elif-hdr">
      <span class="btag btag-else">ELSE</span>
      <button class="ibtn del" onclick="this.closest('.else-blk').parentElement.style.display='none';this.closest('.else-blk').parentElement.innerHTML='';compile()" style="margin-left:auto;">✕</button>
    </div>
    ${mkChild('ELSE body',`else_${eid}`)}
  </div>`;
  wrap.style.display='block';
  wrap.addEventListener('click',e=>{
    const b=e.target.closest('.acb');if(!b)return;e.stopPropagation();
    const slot=b.dataset.slot,t=b.dataset.add;
    const cont=b.closest(`[data-slot="${slot}"]`)?.querySelector(`[data-cont="${slot}"]`);
    if(cont)addBlock(cont,t);
  });
  initPickers(wrap);wireInputs(wrap);compile();
}

function addCountry(btn){
  const body=btn.closest('.bbody');
  const wrap=body.querySelector('.soc-countries');
  const inputs=SOC_PLAT.map(p=>`<div class="soc-field"><label>${p.label}</label><input class="ctrl" style="width:100%;font-size:10px;padding:3px 5px;" data-plat="${p.key}" placeholder="https://…"></div>`).join('');
  const d=document.createElement('div');
  d.innerHTML=`<div class="soc-row" data-country="CUSTOM">
    <div class="soc-hdr">
      <span class="cflag">🏳️</span>
      <input class="ctrl" style="width:120px;font-size:11px;" placeholder="Country name" oninput="compile()">
      <span class="cbadge cbadge-elif">ELIF</span>
      <button class="del-cntry" onclick="this.closest('.soc-row').remove();compile()">✕</button>
    </div>
    <div class="soc-grid">${inputs}</div>
  </div>`;
  const elseRow=wrap.querySelector('[data-is-else="1"]');
  wrap.insertBefore(d.firstElementChild,elseRow);
  d.querySelectorAll('input,select').forEach(i=>i.addEventListener('input',compile));
  compile();
}

// ══════════════════════════════ COMPILER ════════════════════
function compileContainer(container,depth){
  let out='';
  for(const child of container.children){
    if(child.dataset.bid)out+=compileBlock(child,depth);
  }
  return out;
}

function compileBlock(el,depth){
  const ind='  '.repeat(depth);
  const type=el.dataset.type;

  if(type==='text'){
    const val=el.querySelector('.content-ta')?.value||'';
    return val?val.split('\n').map(l=>ind+l).join('\n')+'\n':'';
  }

  if(type==='set'){
    const name=el.querySelector('.set-name')?.value.trim()||'myVar';
    const panel=el.querySelector('.set-panel:not([style*="display: none"]):not([style*="display:none"])')||el.querySelector('[data-panel="tok"]');
    const mode=panel?.dataset.panel||'tok';
    let val='';
    if(mode==='tok'){
      const p=panel.querySelector('.tpick');
      const cat=p?.querySelector('[data-role=cat]')?.value||'userSystem';
      const attr=p?.querySelector('[data-role=val]')?.value?.trim()||'';
      const def=el.querySelector('.set-def')?.value?.trim()||'';
      val=buildPath(cat,attr);if(def)val+=` | default("${def}")`;
    }else if(mode==='static'){
      val=`"${el.querySelector('.set-static')?.value||''}"`;
    }else if(mode==='date'){
      val=`we_date | we_date("${el.querySelector('.set-datefmt')?.value||'MMMM'}")`;
    }else{
      val=el.querySelector('.set-expr')?.value||'';
    }
    return `${ind}{% set ${name} = ${val} %}\n`;
  }

  if(type==='for'){
    const iter=el.querySelector('.for-iter')?.value.trim()||'item';
    const cs=el.querySelector('.for-col');
    const colVal=cs?.value==='__custom__'?(el.querySelector('.for-col-cust')?.value.trim()||'items'):(cs?.value||'items');
    const cont=el.querySelector(`[data-cont^="for_"]`);
    const body=cont?compileContainer(cont,depth+1):'';
    return `${ind}{% for ${iter} in ${colVal} %}\n${body}${ind}{% endfor %}\n`;
  }

  if(type==='if'){
    let out='';
    const ifCond=buildConds(el.querySelector('.cond-rows[data-btype="if"]'));
    const ifCont=el.querySelector(`[data-cont^="if_"]`);
    out+=`${ind}{% if ${ifCond} %}\n`;
    out+=ifCont?compileContainer(ifCont,depth+1):'';
    el.querySelectorAll('.elif-blk').forEach(ew=>{
      const cond=buildConds(ew.querySelector('.cond-rows'));
      const cont=ew.querySelector(`[data-cont^="elif_"]`);
      out+=`${ind}{% elif ${cond} %}\n`;
      out+=cont?compileContainer(cont,depth+1):'';
    });
    const elseCont=el.querySelector(`[data-cont^="else_"]`);
    if(elseCont){out+=`${ind}{% else %}\n`;out+=compileContainer(elseCont,depth+1);}
    out+=`${ind}{% endif %}\n`;
    return out;
  }

  if(type==='rec'){
    const rs=el.querySelector('.rec-slug');
    const slug=rs?.value==='__custom__'?(el.querySelector('.rec-slug-cust')?.value.trim()||'c_recommendation_XXX'):(rs?.value||'c_recommendation_XXX');
    const iter=el.querySelector('.rec-iter')?.value.trim()||'item';
    const maxN=parseInt(el.querySelector('.rec-max')?.value)||8;
    const guard=el.querySelector('.rec-guard')?.checked;
    const even=el.querySelector('.rec-even')?.checked;
    const cap=el.querySelector('.rec-cap')?.checked;
    const cont=el.querySelector(`[data-cont^="rec_"]`);
    const body=cont?compileContainer(cont,depth+1):'';
    let out='';
    out+=`${ind}{% set arr = [] %}\n`;
    out+=`${ind}{% set firstArr = recommend["${slug}"][xargs()] %}\n`;
    out+=`${ind}{% set totalArray = firstArr.length %}\n`;
    if(guard){out+=`${ind}{% if totalArray < 2 %}\n${ind}  {{ "fail_trigger" | filterThatDoesNotExist }}{# hard fail — suppresses send if not enough recs #}\n${ind}{% endif %}\n`;}
    out+=`${ind}{% set arr = arr.concat(firstArr) %}\n`;
    out+=`${ind}{% set total = arr.length %}\n`;
    if(cap)out+=`${ind}{% if total > ${maxN} %}{% set total = ${maxN} %}{% endif %}\n`;
    if(even)out+=`${ind}{% if total % 2 != 0 %}{% set total = total - 1 %}{% endif %}\n`;
    if(body.trim())out+=`${ind}{% for ${iter} in arr %}\n${body}${ind}{% endfor %}\n`;
    return out;
  }

  if(type==='grid'){
    const src=el.querySelector('.grid-src')?.value.trim()||'arr';
    const total=el.querySelector('.grid-total')?.value.trim()||'total';
    const fields=[...el.querySelectorAll('.fpill')].map(p=>p.dataset.field);
    let out='';
    out+=`${ind}{% for i in range(0, ${total}, 2) %}\n`;
    out+=`${ind}  {% set left  = ${src}[i] %}\n`;
    out+=`${ind}  {% set right = ${src}[i + 1] %}\n`;
    out+=`${ind}  {% if left %}\n`;
    fields.forEach(f=>{out+=`${ind}    {{ left['${f}'] }}\n`;});
    out+=`${ind}  {% endif %}\n`;
    out+=`${ind}  {% if right %}\n`;
    fields.forEach(f=>{out+=`${ind}    {{ right['${f}'] }}\n`;});
    out+=`${ind}  {% endif %}\n`;
    out+=`${ind}{% endfor %}\n`;
    return out;
  }

  if(type==='social'){
    const rows=[...el.querySelectorAll('.soc-countries .soc-row')];
    let out='';
    rows.forEach((row,idx)=>{
      const isElse=row.dataset.isElse==='1';
      const urls={};
      row.querySelectorAll('[data-plat]').forEach(inp=>{urls[inp.dataset.plat]=inp.value.trim()||''});
      let tag;
      if(isElse){tag=`{% else %}`;}
      else{
        const ni=row.querySelector('input.ctrl:not([data-plat])');
        const country=ni?ni.value.trim():row.dataset.country;
        tag=idx===0?`{% if user["custom"]["Country"] == "${country}" %}`:`{% elif user["custom"]["Country"] == "${country}" %}`;
      }
      out+=`${ind}${tag}\n`;
      if(urls.ig)     out+=`${ind}  {% set ig_url      = "${urls.ig}" %}\n`;
      if(urls.snap)   out+=`${ind}  {% set snap_url    = "${urls.snap}" %}\n`;
      if(urls.fb)     out+=`${ind}  {% set fb_url      = "${urls.fb}" %}\n`;
      if(urls.tiktok) out+=`${ind}  {% set tiktok_url  = "${urls.tiktok}" %}\n`;
      if(urls.x)      out+=`${ind}  {% set x_url       = "${urls.x}" %}\n`;
      if(urls.threads)out+=`${ind}  {% set threads_url = "${urls.threads}" %}\n`;
    });
    if(rows.length)out+=`${ind}{% endif %}\n`;
    return out;
  }
  return '';
}

function compile(){
  const code=compileContainer(root,0);
  const out=document.getElementById('output');
  out.textContent=code.trim()||'<!-- Add blocks from the left panel →';
  hljs.highlightElement(out);
}
function copyCode(){
  navigator.clipboard.writeText(document.getElementById('output').textContent).then(()=>{
    const btn=document.getElementById('copy-btn');
    btn.textContent='Copied ✓';setTimeout(()=>btn.textContent='Copy',1800);
  });
}

// ══════════════════════════════ PRESETS ══════════════════════
function loadPreset(name){
  if(root.querySelectorAll('[data-bid]').length>0){if(!confirm('Clear canvas and load preset?'))return;}
  root.innerHTML='';root.appendChild(cempty);syncEmpty();

  if(name==='greeting'){
    const el=addBlock(root,'set');
    el.querySelector('.set-name').value='firstName';
    el.querySelector('.set-name').dispatchEvent(new Event('input'));
    const srch=el.querySelector('.tp-srch'),hid=el.querySelector('[data-role=val]');
    srch.value='first_name';hid.value='first_name';
    el.querySelector('.set-def').value='there';
    el.querySelector('.set-def').dispatchEvent(new Event('input'));
    const txtEl=addBlock(root,'text');
    txtEl.querySelector('.content-ta').value='Hello {{ firstName }}! Here\'s what\'s on for you.';
    txtEl.querySelector('.content-ta').dispatchEvent(new Event('input'));
  }

  else if(name==='geo'){
    const el=addBlock(root,'if');
    const cat=el.querySelector('[data-role=cat]');
    cat.value='userCustom';cat.dispatchEvent(new Event('change'));
    const srch=el.querySelector('.tp-srch'),hid=el.querySelector('[data-role=val]');
    srch.value='Country';hid.value='Country';
    el.querySelector('.operator-select').value='==';
    el.querySelector('.value-input').value='UAE';
    el.querySelectorAll('input,select').forEach(i=>i.dispatchEvent(new Event('input')));
  }

  else if(name==='rec_email'){
    // 1. SET currentIST = we_date
    const setEl=addBlock(root,'set');
    setEl.querySelector('.set-name').value='currentIST';
    setEl.querySelector('.set-name').dispatchEvent(new Event('input'));
    const dateTab=setEl.querySelectorAll('.stab')[2];
    if(dateTab)setMode(dateTab,'date');

    // 2. IF first_name is defined
    const ifEl=addBlock(root,'if');
    const cat=ifEl.querySelector('[data-role=cat]');
    cat.value='userSystem';cat.dispatchEvent(new Event('change'));
    const srch=ifEl.querySelector('.tp-srch'),hid=ifEl.querySelector('[data-role=val]');
    srch.value='first_name';hid.value='first_name';
    ifEl.querySelector('.operator-select').value='is defined';
    ifEl.querySelectorAll('input,select').forEach(i=>i.dispatchEvent(new Event('input')));

    // 3. REC
    addBlock(root,'rec');

    // 4. GRID
    addBlock(root,'grid');

    // 5. SOCIAL
    addBlock(root,'social');
  }

  compile();
}

// ══════════════════════════════ INIT ══════════════════════════
syncEmpty();compile();
</script>
