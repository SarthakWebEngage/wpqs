function mkCondRow(first){
  const opOpts=OPS.map(o=>`<option value="${o}">${o}</option>`).join('');
  return `<div class="cond-row">
    ${!first?`<button class="cond-ao" onclick="this.textContent=this.textContent==='AND'?'OR':'AND';compile()">AND</button>`:''}
    ${mkPicker()}
    <select class="ctrl operator-select" style="font-size:11px;padding:3px 6px;">${opOpts}</select>
    <input class="ctrl value-input" style="width:95px;" placeholder="value">
    ${!first?`<button class="cond-del" onclick="this.closest('.cond-row').remove();compile()">✕</button>`:''}
  </div>`;
}
function addCond(btn){
  const block=btn.closest('[data-bid],[data-elif]');
  const rows=block.querySelector('.cond-rows');
  const d=document.createElement('div');d.innerHTML=mkCondRow(false);
  const el=d.firstElementChild;rows.appendChild(el);
  initPickers(el);wireInputs(el);compile();
}
function buildConds(condRows){
  if(!condRows) return 'true';
  const rows=[...condRows.querySelectorAll('.cond-row')];
  if(!rows.length) return 'true';
  return rows.map((row,i)=>{
    const ao=row.querySelector('.cond-ao')?.textContent?.trim().toLowerCase()||'and';
    const p=row.querySelector('.tpick');
    const cat=p?.querySelector('[data-role=cat]')?.value||'userSystem';
    const attr=p?.querySelector('[data-role=val]')?.value?.trim()||'';
    const op=row.querySelector('.operator-select')?.value||'==';
    const val=row.querySelector('.value-input')?.value?.trim()||'';
    const path=buildPath(cat,attr);
    let cond;
    if(op==='is defined') cond=`${path} is defined`;
    else if(op==='is not defined') cond=`${path} is not defined`;
    else if(op==='contains') cond=`${path} | contains("${val}")`;
    else{const qv=val!==''&&!isNaN(val)?val:`"${val}"`;cond=`${path} ${op} ${qv}`}
    return i===0?cond:`${ao} ${cond}`;
  }).join(' ');
}

