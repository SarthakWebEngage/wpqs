function buildPath(catKey,attr){
  const cat=CATS.find(c=>c.key===catKey);
  if(!cat||!attr.trim()) return '...';
  return `${cat.group}["${cat.sub}"]["${attr}"]`;
}
function colOpts(){
  const grps={};
  COLLECTIONS.forEach(c=>{(grps[c.group]=grps[c.group]||[]).push(c)});
  return `<option value="">— select —</option>`+
    Object.entries(grps).map(([g,items])=>`<optgroup label="${g}">${items.map(i=>`<option value="${i.value}" data-hint="${i.hint}">${i.label}</option>`).join('')}</optgroup>`).join('')+
    `<option value="__custom__">✏️ custom…</option>`;
}
function recSlugOpts(){
  return REC_SLUGS.map(r=>`<option value="${r.v}">${r.l}</option>`).join('')+`<option value="__custom__">✏️ custom…</option>`;
}
function autoResize(ta){ta.style.height='auto';ta.style.height=ta.scrollHeight+'px'}
function syncEmpty(){
  cempty.style.display=root.querySelectorAll('[data-bid]').length>0?'none':'flex';
}
function wireInputs(el){
  el.querySelectorAll('textarea.ctrl').forEach(ta=>{
    autoResize(ta);ta.addEventListener('input',()=>{autoResize(ta);compile()});
  });
  el.querySelectorAll('input:not([type=checkbox]):not([type=hidden]),select').forEach(i=>i.addEventListener('input',compile));
  el.querySelectorAll('input[type=checkbox]').forEach(i=>i.addEventListener('change',compile));
}

